{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.MiHarsh/figma-local-mcp",
  "description": "Consume Figma design data from local JSON files — no API key, no rate limits, no internet required.",
  "repository": {
    "url": "https://github.com/MiHarsh/figma-local-mcp",
    "source": "github"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "figma-local-mcp",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "--stdio"
        }
      ]
    }
  ]
}
